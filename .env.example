# ════════════════════════════════════════════════════════
#  효자손 환경 변수 예시 (.env.example)  — 실제 키는 .env 에
#  엔드포인트 URL은 api/lib/datasets.js 참고
# ════════════════════════════════════════════════════════

# AI 비전 모델 (운영: OpenAI gpt-5.4-nano) — 필수
OPENAI_API_KEY=
# (선택) 넣으면 Gemini 2.5 Flash가 폴백으로 자동 추가 (주 모델은 nano)
GEMINI_API_KEY=

# 공공데이터포털 공용 키 (data.go.kr / odcloud) — 아래를 한 키로 사용
#   · KISA 피싱사이트 URL(2층 블랙리스트) · 국세청 사업자등록 진위·상태 · 국토부 실거래가
DATA_GO_KR_API_KEY=

# 금융감독원 DART (기업/법인 실존·공시 확인)
DART_API_KEY=

# 블랙리스트 캐시 (Upstash Redis REST / Vercel KV) — 선택, 없으면 2층 생략
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cron 보호 시크릿 (/api/refresh-blacklist) — openssl rand -hex 16 로 생성
CRON_SECRET=

# (선택) 분석 API IP당 시간당 허용 횟수 — 미설정 시 기본 100. 복지관 공유 와이파이 대비.
ANALYZE_RATE_LIMIT=

# 개발 전용 (런타임/Vercel 불필요): Google Stitch MCP 디자인 툴 키
STITCH_MCP_API_KEY=
